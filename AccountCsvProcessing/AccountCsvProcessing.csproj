<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net9.0</TargetFramework>
        <LangVersion>latestmajor</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>disable</Nullable>
		
        <InvariantGlobalization>true</InvariantGlobalization>
        <AssemblyName>CsvProcessing</AssemblyName>
        <RootNamespace>CsvProcessing</RootNamespace>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="CsvHelper" Version="33.0.1" />
        <PackageReference Include="FuzzySharp" Version="2.0.2" />
        <PackageReference Include="MethodTimer.Fody" Version="3.2.3" />
        <PackageReference Include="Microsoft.EntityFrameworkCore" Version="9.0.5" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\AccountDeduplication.DAL\AccountDeduplication.DAL.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Update="Account.csv">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
      <None Update="IntermediateResults.csv">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </None>
    </ItemGroup>

</Project>
